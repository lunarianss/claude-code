{
  "name": "@claude-codex/desktop",
  "version": "0.1.0",
  "description": "Claude Codex - Desktop GUI for Claude Code",
  "type": "module",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "electron .",
    "build": "vite build",
    "build:main": "bun build src/main/index.ts --outdir dist/main --target node",
    "build:preload": "bun build src/preload/index.ts --outdir dist/preload --target node",
    "package": "electron-builder"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^2.1.0",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "highlight.js": "^11.11.1",
    "fuse.js": "^7.1.0",
    "@monaco-editor/react": "^4.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
